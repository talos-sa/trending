{
  "name": "@talos-sa/trending-svelte",
  "version": "0.1.0",
  "description": "Svelte components for time series data visualization - charts, legends, cursors, and export",
  "type": "module",
  "svelte": "./dist/index.js",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "svelte-package && cp dist/index.d.ts dist/index.d.cts 2>/dev/null; true",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@talos-sa/trending-core": "^0.1.0"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "trending",
    "chart",
    "timeseries",
    "svelte",
    "visualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/talos-sa/trending.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
