{
  "name": "@talos-sa/trending-vue",
  "version": "0.1.0",
  "description": "Vue 3 components for time series data visualization - charts, legends, cursors, and export",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@talos-sa/trending-core": "^0.1.0"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "^5.8.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "keywords": [
    "trending",
    "chart",
    "timeseries",
    "vue",
    "visualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/talos-sa/trending.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
