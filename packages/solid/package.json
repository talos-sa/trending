{
  "name": "@talos-sa/trending-solid",
  "version": "0.1.0",
  "description": "Solid components for time series data visualization - charts, legends, cursors, and export",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external solid-js",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external solid-js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@talos-sa/trending-core": "^0.1.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "solid-js": "^1.9.0"
  },
  "keywords": [
    "trending",
    "chart",
    "timeseries",
    "solid",
    "visualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/talos-sa/trending.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
